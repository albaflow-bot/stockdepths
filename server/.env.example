# Server env keys. BinDesk auto-injects these at the 'DB 연결' build step — you
# only write *reading* code (DB BACKEND 계약). Copy to .env.local for local runs.

# Supabase — production storage for the daily-picks artifact + append-only track
# record (run supabase/schema.sql once to create the tables). When SUPABASE_URL +
# a key are set, the stores persist to Supabase (the Vercel/serverless path);
# otherwise they fall back to local disk (dev/test). Prefer the service-role key
# for the batch writer; the anon key is read-mostly.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
DATABASE_URL=

# --- Market data ingestion (Task 1) ---
# No API keys required: Stooq + Yahoo Finance + RSS/Atom feeds are all free,
# keyless sources. These optional overrides exist for tuning only.

# Per-attempt HTTP timeout in ms (default 8000).
# MARKET_HTTP_TIMEOUT_MS=8000

# --- Daily recommendation batch (Task 2) ---
# At least ONE provider key is required (the batch aborts rather than fabricating
# picks if none is set). Use whichever fits your cost model:
#
#   FREE tier  → set GEMINI_API_KEY only and PICKS_PRIMARY=gemini. One oneshot per
#                day stays well within Gemini's free quota, so AI cost is ~0.
#   QUALITY    → set ANTHROPIC_API_KEY (Claude Sonnet 4.6, paid). It becomes primary
#                by default; Gemini (if set) is the failover.
#   BOTH       → keep PICKS_PRIMARY=gemini to run free normally, with Claude as a
#                paid backup that only fires when Gemini fails.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Force the primary provider regardless of load: "gemini" (free) | "anthropic".
# Unset = load-based default (Anthropic-first, Gemini on high load).
PICKS_PRIMARY=

# Optional overrides (sane defaults applied if unset):
# ANTHROPIC_PICKS_MODEL=claude-sonnet-4-6
# GEMINI_PICKS_MODEL=gemini-2.0-flash
# PICKS_UNIVERSE=AAPL,MSFT,NVDA,AMZN,GOOGL   # comma-separated candidate tickers
# SERVER_LOAD=0                              # 0..1; >=0.8 prefers Gemini (cost scaling)

# --- FCM push backbone (Task 5) — 요구 토큰: 원격 푸시(v1 핵심) ---
# Firebase service account for the daily digest push (Android via FCM HTTP v1).
# 푸시(앱 꺼져 있어도 도착)를 켜려면 필수. 미설정 시 push 는 graceful skip
# (앱·추천·로컬 알림은 정상). Provide ONE of the following:
#   - Inline JSON (escape newlines in the private_key as \n):
# FCM_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
#   - Or a path to the service-account JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#
# On-device holding alerts (target/stop) need NO server credentials — the rule
# engine runs on-device with no per-user LLM (see src/alerts/).

# --- Email (Task 13) ---
# Resend API key for transactional/announcement email (server-side only — never
# exposed to the client). Without it, `npm run email:announce` skips gracefully.
RESEND_API_KEY=
# Verified sender address for outgoing mail (e.g. "AI 주식 타이밍 알리미 <launch@yourdomain.com>").
EMAIL_FROM=
