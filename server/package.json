{
  "name": "stock-timing-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Server-side backend for AI 주식 타이밍 알리미 — market data ingestion, daily picks, backtesting, scorecard.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:us": "tsx src/scripts/demo-us.ts",
    "batch:daily": "tsx src/scripts/run-daily-batch.ts",
    "batch:cli": "tsx src/scripts/run-batch-claudecli.ts",
    "batch:screen": "tsx src/scripts/run-screen-batch.ts",
    "refresh": "tsx src/scripts/refresh-all.ts",
    "release:publish": "tsx src/scripts/publish-release.ts",
    "ingest:master:us": "tsx src/scripts/ingest-master-us.ts",
    "ingest:us:snapshot": "tsx src/scripts/ingest-us-nasdaq.ts",
    "ingest:kr": "tsx src/scripts/ingest-kr-naver.ts",
    "backtest": "tsx src/scripts/run-backtest.ts",
    "scorecard": "tsx src/scripts/show-scorecard.ts",
    "push:digest": "tsx src/scripts/run-push-digest.ts",
    "alerts:demo": "tsx src/scripts/alerts-demo.ts",
    "email:announce": "tsx src/scripts/send-announcement.ts",
    "api": "tsx src/scripts/run-api.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
