# Client env (Expo inlines EXPO_PUBLIC_* into the bundle at build time).

# Base URL of the picks API (the server that serves the daily artifact).
# Without it, the home screen shows a friendly "서버 미연결" message rather than
# crashing (RESILIENCE / DB BACKEND contracts).
EXPO_PUBLIC_API_BASE_URL=

# --- Analytics (Task 13) ---
# Privacy-friendly Plausible analytics. Set the domain to enable funnel tracking
# (persona_set / pick_view / alert_opt_in). Unset = analytics disabled (no-op).
EXPO_PUBLIC_PLAUSIBLE_DOMAIN=
# Optional self-hosted Plausible host (defaults to https://plausible.io).
EXPO_PUBLIC_PLAUSIBLE_HOST=

# --- Firebase (FCM 원격 푸시) — env 아닌 파일 산출물 ---
# 원격 푸시(앱 꺼져 있어도 도착)는 google-services.json 파일이 필요합니다(환경변수 아님).
# Firebase 콘솔/CLI 로 안드로이드 앱(com.bindesk.stocktiming) 등록 후 받은 파일을
#   mobile/android/app/google-services.json
# 에 두면 다음 빌드부터 활성화됩니다. 파일이 없으면 빌드는 정상이고 원격 푸시만
# 비활성화(로컬 알림은 동작) — android/app/build.gradle 이 조건부로 적용합니다.
